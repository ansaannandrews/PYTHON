#Reverse of a number using function
def reverse(x):
    b=0
    while x>0:
        a=x%10
        b=b*10+a
        x=x//10
    return b

n=int(input())
result = reverse(n)
print(result)

#Factorial of a number using function
def factorial(a):
    fact=1
    for i in range(2,a+1):
        fact*=i
    return fact

n=int(input())
result = factorial(n)
print(result)

